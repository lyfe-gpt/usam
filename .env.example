# Airtable Personal Access Token used by the website forms to create leads.
#
# Create at: https://airtable.com/create/tokens
#   Scope:  data.records:write   (write only — NOT read)
#   Access: USAM Sales Pipeline base only
#
# This value ends up in the public JS bundle, so keep it write-only and
# scoped to the single base. Rotate it from the token page if abused.
#
# Local dev: copy this file to .env.local and paste your token below.
# Production: add the same value as a GitHub Actions secret named
#             VITE_AIRTABLE_TOKEN (repo Settings → Secrets → Actions).
VITE_AIRTABLE_TOKEN=patXXXXXXXXXXXXXX.XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ---------------------------------------------------------------------------
# Analytics & advertising tags (ALL OPTIONAL)
#
# Each tag stays completely dormant until BOTH its ID below is set AND the
# visitor accepts cookies in the consent banner. Leave any line blank/removed
# to keep that platform off. These IDs are public by design (they ship in the
# client bundle), so only paste publishable measurement IDs here — never an
# API secret or access token.
#
# Set the ones you use, locally in .env.local and in production as GitHub
# Actions secrets of the same name (repo Settings → Secrets → Actions).
# ---------------------------------------------------------------------------

# Google Analytics 4 — Admin → Data Streams → your stream ("G-XXXXXXXXXX")
VITE_GA4_ID=

# Google Ads — Tools → Conversions → tag setup ("AW-XXXXXXXXX")
VITE_GOOGLE_ADS_ID=
# Optional Google Ads conversion labels ("AW-XXXXXXXXX/AbC-D_efGh"), one per action
VITE_GOOGLE_ADS_LEAD_LABEL=
VITE_GOOGLE_ADS_APPLY_LABEL=
VITE_GOOGLE_ADS_CALL_LABEL=
VITE_GOOGLE_ADS_PARTNER_LABEL=

# Meta (Facebook) Pixel — Events Manager → Data Sources (numeric pixel ID)
VITE_META_PIXEL_ID=

# Microsoft Clarity — Settings → Overview → install code (10-char project ID)
VITE_CLARITY_ID=

# LinkedIn Insight Tag — Campaign Manager → Account Assets → Insight Tag (numeric partner ID)
VITE_LINKEDIN_PARTNER_ID=

# Enhanced conversions (Google): pass lead email/phone to Google (hashed
# client-side) for better match rates and attribution. Off by default — set to
# "true" only after enabling Enhanced Conversions in the Google Ads UI. PII is
# only sent after a visitor accepts cookies.
VITE_ENHANCED_CONVERSIONS=

# Force-enable the in-page event debug log (window.__usamAnalytics) in a
# production build for QA. Always on in dev. Leave blank for production.
VITE_ANALYTICS_DEBUG=
